# OPENAI_COMPAT_TEMPERATURE=0.2
# OPENAI_COMPAT_MAX_TOKENS=4096
# OPENAI_COMPAT_TIMEOUT_MS=120000
# OPENAI_COMPAT_JSON_MODE=true
# OPENAI_COMPAT_THINKING=unset
